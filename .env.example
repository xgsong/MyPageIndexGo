# PageIndex Sensitive Configuration
# Copy this file to .env and fill in your sensitive credentials
# All non-sensitive configuration must be set in config.yaml file

# OpenAI API Key (REQUIRED)
OPENAI_API_KEY=your_openai_api_key_here

# OCR API Keys (only required if using cloud OCR providers)
# Local OCR services like Llama.cpp do not require API keys
# OCR_API_KEY=your_ocr_provider_api_key_here

# IMPORTANT: All other configuration options are now in config.yaml
# Please edit config.yaml to set LLM models, OCR settings, concurrency, etc.
